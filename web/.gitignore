# ==========================================
# VIZIER Monorepo - Git Ignore Configuration
# ==========================================

# --- Python / Backend ---
.venv/
venv/
ENV/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# --- Node / Frontend (web/) ---
node_modules/
web/node_modules/
.next/
web/.next/
out/
web/out/

# --- Environment Files & Secrets (CRITICAL) ---
.env
.env.*
!.env.example
backend/.env
web/.env.local
web/.env.development.local
web/.env.test.local
web/.env.production.local

# Banned secret directories (only permit READMEs)
backend/secrets/*
!backend/secrets/README.md

# Token caches & Local credentials
*token*.json
*token*.pickle
*credentials*.json
!backend/secrets/README.md

# --- OS & IDEs ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.gemini/
.agents/

# --- Build & Output Artifacts ---
build/
dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
